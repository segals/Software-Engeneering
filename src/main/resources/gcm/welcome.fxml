<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<!--
    Welcome screen layout for the GCM system.
    Controller: WelcomeController

    Shown after a successful login.
    The welcomeLabel is set by WelcomeController.initialize() to show:
    "Welcome, <username>!"
-->
<AnchorPane prefHeight="300.0" prefWidth="350.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gcm.WelcomeController">

    <!-- Welcome message label — populated by WelcomeController.initialize() -->
    <Label fx:id="welcomeLabel"
           layoutX="50.0" layoutY="120.0"
           prefWidth="250.0"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

</AnchorPane>
