<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="320.0" prefWidth="420.0"
           style="-fx-background-color: #f0f2f5;"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="gcm.WelcomeController">
    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <VBox spacing="14" alignment="CENTER" fillWidth="true"
          style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;">
        <padding><Insets top="36" right="32" bottom="36" left="32"/></padding>

        <Label text="Login Successful"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #222222;" />

        <Label fx:id="welcomeLabel" wrapText="true" maxWidth="Infinity"
               style="-fx-font-size: 14px; -fx-text-fill: #444444;" />

        <Button text="Log Out" maxWidth="Infinity"
                onAction="#handleLogout"
                style="-fx-background-color: white; -fx-text-fill: #2196F3; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #2196F3; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 0 8 0; -fx-cursor: hand;" />

    </VBox>
</StackPane>
